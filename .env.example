# LLM Provider: openai | anthropic | bedrock
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


DYNAMODB_TABLE_NAME=tool_results
DYNAMODB_ENDPOINT_URL=http://localhost:8000

# App
BACKEND_PORT=8080
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO

# Summarization
SUMMARIZE_TOKEN_THRESHOLD=4000
